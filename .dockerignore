# Docker build context exclusions
# This file reduces build context size and speeds up builds

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments (on network volume, not in image)
venv/
env/
ENV/
.venv/

# Models (on network volume, not in image)
models/
*.ckpt
*.safetensors
*.gguf
*.pth
*.pt
*.bin

# Outputs and temporary files
output/
temp/
input/
user/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation (not needed in runtime image)
*.md
docs/
_design_docs/

# CI/CD
.github/
.gitlab-ci.yml

# Testing
tests/
test/
*.test.js
*.test.py

# Jupyter
*.ipynb
.ipynb_checkpoints/

# Node modules (if any)
node_modules/
package-lock.json

# Large custom node caches
custom_nodes/**/models/
custom_nodes/**/__pycache__/
custom_nodes/**/node_modules/

# Manager caches
custom_nodes/ComfyUI-Manager/.cache/
custom_nodes/ComfyUI-Manager/snapshots/

# Local development
*.local
.env
.env.local

# Logs
*.log
logs/

# Backup files
*.bak
*.backup

# Serverless testing artifacts (keep source files)
serverless/test_*.py
serverless/docker-compose*.yml
serverless/workspace/
serverless/examples/
