# ComfyUI WAN 2.2 Serverless Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# S3/R2 Configuration (Required for output uploads)
# =============================================================================

# Cloudflare R2 Endpoint
# Format: https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ENDPOINT=

# R2 Access Credentials
R2_ACCESS_KEY=
R2_SECRET_KEY=

# R2 Bucket Name
R2_BUCKET=comfyui-outputs

# R2 Public URL (optional - for custom domain)
# Format: https://your-custom-domain.com
R2_PUBLIC_URL=

# Alternative: AWS S3 Configuration
# S3_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=comfyui-outputs
# S3_PUBLIC_URL=

# =============================================================================
# ComfyUI Paths (Network Volume)
# =============================================================================

# Models directory (on network volume)
MODELS_DIR=/workspace/models

# Output directory (on network volume)
OUTPUT_DIR=/workspace/output

# Temporary directory (on network volume)
TEMP_DIR=/workspace/temp

# Python virtual environment path (on network volume)
VENV_PATH=/workspace/venv

# =============================================================================
# Cache Configuration
# =============================================================================

# Cache type: RAM_PRESSURE, LRU, CLASSIC, NONE
# RAM_PRESSURE = aggressive memory cleanup (recommended for serverless)
CACHE_TYPE=RAM_PRESSURE

# RAM threshold in GB for RAM_PRESSURE cache
# When system RAM exceeds this, models are aggressively unloaded
CACHE_RAM=16.0

# =============================================================================
# Feature Toggles
# =============================================================================

# Enable model warmup on cold start
# Preloads VAE + T5 encoder (~4GB VRAM) for faster first generation
# true = 50-60s cold start, false = 90s cold start
WARMUP_MODELS=true

# Clean up local output files after S3 upload
# true = delete after upload, false = keep local copies
CLEANUP_OUTPUTS=true

# =============================================================================
# CUDA Optimization
# =============================================================================

# Lazy CUDA module loading (faster startup)
CUDA_MODULE_LOADING=LAZY

# PyTorch CUDA allocator configuration
# expandable_segments = allow memory pool to expand
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# =============================================================================
# Docker Build Configuration (for local builds)
# =============================================================================

# Docker registry
REGISTRY=ghcr.io/YOUR_GITHUB_USERNAME

# Image name
IMAGE_NAME=comfyui_wan/comfyui-wan-serverless

# Version tag
VERSION=latest

# =============================================================================
# GitHub Actions Configuration (for automated builds)
# =============================================================================

# GitHub Personal Access Token (for GitHub Container Registry)
# Generate at: https://github.com/settings/tokens
# Required scopes: write:packages, read:packages
GITHUB_TOKEN=

# =============================================================================
# RunPod Configuration (for deployment)
# =============================================================================

# RunPod API Key (for programmatic deployment)
# Get from: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=

# Network Volume ID (from RunPod dashboard)
NETWORK_VOLUME_ID=

# =============================================================================
# Local Testing Configuration
# =============================================================================

# Path to network volume for local testing
# Use local directory or mounted network volume
WORKSPACE_PATH=./workspace

# RunPod endpoint URL for remote testing
# Format: https://api.runpod.ai/v2/YOUR_ENDPOINT_ID
RUNPOD_ENDPOINT_URL=
