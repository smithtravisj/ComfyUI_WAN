{
  "_meta": {
    "description": "Fast Text-to-Video with Lightning LoRA (4-step generation)",
    "purpose": "Quick video generation using Lightning LoRA optimization",
    "model": "Wan2.2-T2V-A14B-HighNoise-Q8_0.gguf + Lightning LoRA",
    "duration": "~30-40 seconds (after warmup)",
    "vram": "~18-20GB peak",
    "output": "MP4 video, ~4 seconds @ 24fps",
    "note": "4 steps instead of 25 for 6x faster generation"
  },
  "1": {
    "inputs": {
      "clip_name1": "umt5-xxl-encoder-Q5_K_S.gguf",
      "clip_name2": "umt5-xxl-encoder-Q5_K_S.gguf",
      "type": "gguf"
    },
    "class_type": "DualCLIPLoader",
    "_meta": {
      "title": "Load Text Encoder"
    }
  },
  "2": {
    "inputs": {
      "text": "A cute puppy running through a field of flowers, sunny day, high quality",
      "clip": ["1", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "3": {
    "inputs": {
      "text": "blurry, low quality, distorted",
      "clip": ["1", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "4": {
    "inputs": {
      "vae_name": "wan_2.1_vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {
      "title": "Load VAE"
    }
  },
  "5": {
    "inputs": {
      "unet_name": "Wan2.2-T2V-A14B-HighNoise-Q8_0.gguf"
    },
    "class_type": "UNETLoader",
    "_meta": {
      "title": "Load T2V UNET"
    }
  },
  "6": {
    "inputs": {
      "lora_name": "Wan2_2-T2V-A14B-HighNoise-Lightning-4step-lora.safetensors",
      "strength_model": 1.0,
      "model": ["5", 0]
    },
    "class_type": "LoraLoader",
    "_meta": {
      "title": "Load Lightning LoRA (4-step)"
    }
  },
  "7": {
    "inputs": {
      "width": 832,
      "height": 480,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {
      "title": "Initialize Latent"
    }
  },
  "8": {
    "inputs": {
      "seed": 123456,
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0,
      "model": ["6", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["7", 0]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "Sample (4 steps only!)",
      "note": "Lightning LoRA allows 4 steps instead of 25"
    }
  },
  "9": {
    "inputs": {
      "samples": ["8", 0],
      "vae": ["4", 0]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "Decode to Pixels"
    }
  },
  "10": {
    "inputs": {
      "filename_prefix": "wan_lightning",
      "fps": 24,
      "format": "video/h264-mp4",
      "images": ["9", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": {
      "title": "Save as MP4"
    }
  }
}
